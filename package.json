    "drizzle-orm": "^0.45.1",
    "h3": "2.0.1-rc.14",
    "lucide-vue-next": "^0.575.0",
    "nuxt": "^4.3.1",
    "pg": "^8.19.0",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "srvx": "^0.11.8",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vue": "^3.5.29"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tailwindcss/forms": "^0.5.11",
