    "test:server": "vitest run",
    "test:server:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tsc": "nuxt typecheck",
    "quality": "pnpm run test && pnpm run lint && pnpm run tsc",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts"
  },
  "dependencies": {
