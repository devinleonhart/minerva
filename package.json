{
  "name": "minerva",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=10.28.0"
  },
  "scripts": {
    "dev": "docker compose up --build",
    "start": "docker compose up --build",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "nodemon --watch server --ext ts --exec tsx server/index.ts",
    "build": "pnpm run clean && pnpm install && pnpm run prisma:generate && pnpm run build:client && pnpm run build:server",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc --project server/tsconfig.json",
    "test": "pnpm run test:client && pnpm run test:server",
    "test:client": "vitest run --config client/vite.config.ts",
    "test:server": "vitest run --config server/vitest.config.ts",
    "test:server:coverage": "vitest run --config server/vitest.config.ts --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tsc": "vue-tsc --noEmit --project client/tsconfig.json && tsc --noEmit --project server/tsconfig.json",
    "quality": "pnpm run test && pnpm run lint && pnpm run tsc",
    "prisma:generate": "prisma generate --schema=./server/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./server/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=./server/prisma/schema.prisma",
    "db:seed": "tsx server/prisma/seed.ts",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@prisma/client-runtime-utils": "^7.2.0",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.562.0",
    "pg": "^8.17.1",
    "pinia": "^3.0.4",
    "prisma": "^7.2.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/vue": "^8.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.9",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "@vue/compiler-dom": "^3.5.26",
    "@vue/test-utils": "2.4.6",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.7.0",
    "globals": "^17.0.0",
    "jsdom": "^27.4.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.17",
    "vue-tsc": "^3.2.2"
  }
}
