{
  "name": "minerva",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.30.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "docker compose up --build",
    "start": "docker compose up --build",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "nodemon --watch server --ext ts --exec tsx server/index.ts",
    "build": "pnpm run clean && pnpm install && pnpm run build:client && pnpm run build:server",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc --project server/tsconfig.json",
    "test": "pnpm run test:client && pnpm run test:server",
    "test:client": "vitest run --config client/vite.config.ts",
    "test:server": "vitest run --config server/vitest.config.ts",
    "test:server:coverage": "vitest run --config server/vitest.config.ts --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tsc": "vue-tsc --noEmit --project client/tsconfig.json && tsc --noEmit --project server/tsconfig.json",
    "quality": "pnpm run test && pnpm run lint && pnpm run tsc",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/prisma/seed.ts",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.575.0",
    "pg": "^8.19.0",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/vue": "^8.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/compiler-dom": "^3.5.29",
    "@vue/test-utils": "2.4.6",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
