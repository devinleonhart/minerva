{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "outDir": "../dist/server",
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "index.ts", "test/**/*.ts"]
}
